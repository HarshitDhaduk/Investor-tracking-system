<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Investor Account Credentials</title>
</head>

<body style="margin:0; padding:0; background-color:#01303F;">

    <!-- Full-width background table to enforce background color -->
    <table width="100%" cellpadding="0" cellspacing="0" border="0" bgcolor="#01303F" style="background-color:#01303F; padding:30px 15px;">
        <tr>
            <td align="center">

                <!-- Container Table -->
                <table width="600" cellpadding="0" cellspacing="0" border="0" style="background-color:#01303F; border:1px solid #114656; border-radius:14px; padding:35px;">

                    <!-- Header (Text Logo) -->
                    <tr>
                        <td align="center" style="padding-bottom:20px;">
                            <span style="font-family: Arial, sans-serif; font-size:24px; font-weight:bold; color:#4EF0D5;">
                                Morval Investments
                            </span>
                        </td>
                    </tr>

                    <!-- Title -->
                    <tr>
                        <td>
                            <h2 style="color:#4EF0D5; font-size:22px; margin:0 0 15px 0; text-align:center;">
                                Your Investor Account Credentials
                            </h2>
                        </td>
                    </tr>

                    <!-- Message -->
                    <tr>
                        <td style="color:#D8EDEE; font-size:15px; line-height:1.6;">
                            <p>Hello <%= name %>,</p>
                            <p>An administrator has created an investor account for you. Below are your temporary login credentials:</p>
                        </td>
                    </tr>

                    <!-- Credentials Box -->
                    <tr>
                        <td style="padding:20px 0;">
                            <table width="100%" cellpadding="15" cellspacing="0" border="0" style="background-color:#114656; border-radius:8px;">
                                <tr>
                                    <td style="color:#D8EDEE; font-size:15px;">
                                        <p style="margin:0 0 10px 0;"><strong style="color:#4EF0D5;">Email:</strong> <%= email %></p>
                                        <p style="margin:0;"><strong style="color:#4EF0D5;">Temporary Password:</strong> <span style="font-family:monospace; color:#ffffff;"><%= temp_password %></span></p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Important Notice -->
                    <tr>
                        <td style="color:#D8EDEE; font-size:15px; line-height:1.6;">
                            <p><strong style="color:#4EF0D5;">Important:</strong></p>
                            <ul style="margin:10px 0; padding-left:20px;">
                                <li>This is a temporary password that must be changed upon your first login</li>
                                <li>Please keep these credentials secure and do not share them</li>
                                <li>You will be prompted to create a new password after logging in</li>
                            </ul>
                        </td>
                    </tr>

                    <!-- Security Notice -->
                    <tr>
                        <td style="color:#D8EDEE; font-size:15px; line-height:1.6;">
                            <p>If you did not expect to receive this email or have any questions, please contact your administrator immediately.</p>
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td align="center" style="padding-top:30px; border-top:1px solid #114656; color:#90A8AB; font-size:12px;">
                            <p>© 2024 Morval Investments. All rights reserved.</p>
                            <p>This is an automated email. Please do not reply to this message.</p>
                        </td>
                    </tr>

                </table>
                <!-- End Container -->

            </td>
        </tr>
    </table>

</body>
</html>
