<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Your Password</title>
</head>

<body style="margin:0; padding:0; background-color:#01303F;">

    <!-- Full background wrapper -->
    <table width="100%" cellpadding="0" cellspacing="0" border="0" bgcolor="#01303F" style="background-color:#01303F; padding:30px 15px;">
        <tr>
            <td align="center">

                <!-- Main container -->
                <table width="600" cellpadding="0" cellspacing="0" border="0" style="background-color:#01303F; border:1px solid #114656; border-radius:14px; padding:35px;">

                    <!-- HEADER (Text Logo) -->
                    <tr>
                        <td align="center" style="padding-bottom:25px;">
                            <span style="font-family: Arial, sans-serif; font-size:24px; font-weight:bold; color:#4EF0D5;">
                                Morval Investments
                            </span>
                        </td>
                    </tr>

                    <!-- TITLE -->
                    <tr>
                        <td>
                            <h2 style="color:#4EF0D5; font-size:22px; margin:0 0 15px 0;">
                                Reset Your Password
                            </h2>
                        </td>
                    </tr>

                    <!-- BODY CONTENT -->
                    <tr>
                        <td style="color:#D8EDEE; font-size:15px; line-height:1.6;">
                            <p>Hello <%= name %>,</p>
                            <p>We received a request to reset your password for your Morval Investments account. Click the button below to reset your password:</p>
                        </td>
                    </tr>

                    <!-- BUTTON -->
                    <tr>
                        <td align="center" style="padding:20px 0;">
                            <a href="<%= resetLink %>"
                               style="background:#14B8A6; color:#ffffff; text-decoration:none; padding:12px 30px; font-weight:bold; border-radius:8px; display:inline-block;">
                                Reset Password
                            </a>
                        </td>
                    </tr>

                    <!-- BACKUP LINK -->
                    <tr>
                        <td style="color:#D8EDEE; font-size:15px; line-height:1.6;">
                            <p>If the button doesn't work, copy and paste this link into your browser:</p>
                            <p style="word-break:break-all; color:#4EF0D5;"><%= resetLink %></p>
                            <p>If you didn't request this password reset, please ignore this email. Your password will remain unchanged.</p>
                        </td>
                    </tr>

                    <!-- FOOTER -->
                    <tr>
                        <td align="center" style="padding-top:30px; border-top:1px solid #114656; color:#90A8AB; font-size:12px;">
                            <p>© 2025 Morval Investments. All rights reserved.</p>
                            <p>This is an automated email. Please do not reply to this message.</p>
                        </td>
                    </tr>

                </table>
                <!-- End container -->

            </td>
        </tr>
    </table>

</body>
</html>
