<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Account Deletion Confirmation</title>
</head>

<body style="margin:0; padding:0; background-color:#01303F;">

    <!-- Full-width background table to enforce background color -->
    <table width="100%" cellpadding="0" cellspacing="0" border="0" bgcolor="#01303F" style="background-color:#01303F; padding:30px 15px;">
        <tr>
            <td align="center">

                <!-- Container Table -->
                <table width="600" cellpadding="0" cellspacing="0" border="0" style="background-color:#01303F; border:1px solid #114656; border-radius:14px; padding:35px;">

                    <!-- Header (Text Logo) -->
                    <tr>
                        <td align="center" style="padding-bottom:20px;">
                            <span style="font-family: Arial, sans-serif; font-size:24px; font-weight:bold; color:#4EF0D5;">
                                Morval Investments
                            </span>
                        </td>
                    </tr>

                    <!-- Title -->
                    <tr>
                        <td>
                            <h2 style="color:#4EF0D5; font-size:22px; margin:0 0 15px 0; text-align:center;">
                                Account Deletion Confirmation
                            </h2>
                        </td>
                    </tr>

                    <!-- Message -->
                    <tr>
                        <td style="color:#D8EDEE; font-size:15px; line-height:1.6;">
                            <p>Dear <%= name %>,</p>
                            <p>Your Morval Investments account has been successfully deleted as requested.</p>
                        </td>
                    </tr>

                    <!-- Details Box -->
                    <tr>
                        <td style="padding:20px 0;">
                            <table width="100%" cellpadding="15" cellspacing="0" border="0" style="background-color:#114656; border-radius:8px;">
                                <tr>
                                    <td style="color:#D8EDEE; font-size:15px;">
                                        <p style="margin:0 0 10px 0;"><strong style="color:#4EF0D5;">What this means:</strong></p>
                                        <ul style="margin:0; padding-left:20px;">
                                            <li>Your account data has been removed from our system</li>
                                            <li>You will no longer be able to log in with your credentials</li>
                                            <li>All associated information has been deleted</li>
                                        </ul>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Security Notice -->
                    <tr>
                        <td style="color:#D8EDEE; font-size:15px; line-height:1.6;">
                            <p><strong style="color:#4EF0D5;">Important:</strong> If you did not request this deletion, please contact our support team immediately.</p>
                            <p>Thank you for using Morval Investments. We're sorry to see you go.</p>
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td align="center" style="padding-top:30px; border-top:1px solid #114656; color:#90A8AB; font-size:12px;">
                            <p>© 2025 Morval Investments. All rights reserved.</p>
                            <p>This is an automated email. Please do not reply to this message.</p>
                        </td>
                    </tr>

                </table>
                <!-- End Container -->

            </td>
        </tr>
    </table>

</body>
</html>
